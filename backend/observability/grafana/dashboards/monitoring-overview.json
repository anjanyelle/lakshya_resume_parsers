{
  "title": "Monitoring Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "Real-time Parsing Jobs",
      "targets": [
        {
          "expr": "sum(rate(parsing_jobs_total[1m]))",
          "legendFormat": "jobs/min"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 7 }
    },
    {
      "type": "timeseries",
      "title": "Recent Errors",
      "targets": [
        {
          "expr": "sum(rate(api_request_errors_total[5m]))",
          "legendFormat": "errors/min"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 7 }
    },
    {
      "type": "timeseries",
      "title": "Performance Trends (Latency P95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(api_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 7 }
    }
  ]
}
