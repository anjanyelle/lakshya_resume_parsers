# App Settings
APP_NAME="Resume Parser API"
ENVIRONMENT=development
API_V1_STR=/api/v1
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL="postgresql+psycopg2://postgres:postgres@localhost:5432/resume_parser"
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Storage
STORAGE_DIR=./storage
UPLOAD_MAX_SIZE_MB=20
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
ALLOWED_UPLOAD_EXTENSIONS=["pdf","doc","docx","txt","rtf","png","jpg","jpeg"]

# Parsing Settings
PARSING_MODE=deterministic
LLM_PROVIDER=none

# Optional: Disable ClamAV if not needed
CLAMAV_ENABLED=false

# Redis (optional, leave empty if not using)
REDIS_URL=redis://localhost:6379