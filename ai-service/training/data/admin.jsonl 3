acy.\n\nTECHNICAL SKILLS SUMMARY\n\nBackend:\nJava (8\/11\/17), Spring Boot, Spring Cloud, Hibernate, JPA, MyBatis, REST, GraphQL, gRPC\n\nFrontend:\nReact.js, Angular 15, TypeScript, Redux, Tailwind CSS, WebSocket\n\nDatabases:\nPostgreSQL, MySQL, MongoDB, Redis, Oracle DB, Cassandra, Elasticsearch\n\nCloud & DevOps:\nAWS (EC2, ECS, EKS, RDS, S3, Lambda), GCP, Docker, Kubernetes, Jenkins, GitLab CI\/CD\n\nMessaging:\nApache Kafka, RabbitMQ, AWS SQS\/SNS\n\nTesting:\nJUnit 5, Mockito, Testcontainers, Selenium, Cypress, SonarQube","label":[[0,4,"PERSON_NAME"],[5,30,"JOB_TITLE"],[42,58,"PHONE_NUMBER"],[62,81,"EMAIL"],[85,109,"LOCATION"],[113,137,"LINKEDIN"],[140,159,"GITHUB"],[182,207,"JOB_TITLE"],[213,216,"EXPERIANCE_YEARS"],[263,276,"SKILL"],[339,344,"SKILL"],[367,378,"SKILL"],[382,405,"SKILL"],[410,425,"SKILL"],[451,479,"SKILL"],[551,564,"SKILL"],[566,586,"SKILL"],[592,601,"SKILL"],[618,624,"SKILL"],[655,661,"SKILL"],[690,697,"SKILL"],[703,715,"SKILL"],[717,729,"SKILL"],[730,739,"SKILL"],[741,751,"SKILL"],[754,764,"SKILL"],[765,775,"SKILL"],[777,781,"SKILL"],[783,790,"SKILL"],[791,802,"SKILL"],[804,810,"SKILL"],[812,820,"SKILL"],[822,827,"SKILL"],[828,832,"SKILL"],[834,841,"SKILL"],[843,854,"SKILL"],[856,859,"SKILL"],[860,868,"SKILL"],[870,875,"SKILL"],[877,882,"SKILL"],[884,893,"SKILL"],[894,900,"SKILL"],[902,911,"SKILL"],[912,924,"SKILL"],[925,933,"SKILL"],[935,947,"SKILL"],[950,964,"SKILL"],[965,971,"SKILL"],[973,981,"SKILL"],[983,991,"SKILL"],[993,1002,"SKILL"],[1004,1013,"SKILL"],[1032,1056,"CERTIFICATION"],[1076,1107,"CERTIFICATION"],[1129,1157,"CERTIFICATION"],[1253,1294,"ACHIEVEMENT"],[1304,1344,"ACHIEVEMENT"],[1363,1369,"DEGREE"],[1372,1388,"FIELD_OF_STUDY"],[1389,1392,"UNIVERSITY"],[1394,1405,"LOCATION"],[1407,1418,"GRADUATION_YEAR"],[1425,1428,"GPA"],[1466,1496,"JOB_TITLE"],[1497,1515,"WORK_PERIOD"],[1516,1542,"COMPANY_NAME"],[1545,1559,"LOCATION"],[1591,1602,"SKILL"],[1626,1637,"SKILL"],[1640,1648,"SKILL"],[1724,1732,"SKILL"],[1764,1777,"SKILL"],[1862,1